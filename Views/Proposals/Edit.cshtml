@model BlindMatchPAS.Models.ProjectProposal

@{
    ViewData["Title"] = "Edit Proposal";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="StudentDashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Edit Proposal</li>
      </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Edit Project Proposal</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label font-weight-bold"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Abstract" class="form-label font-weight-bold"></label>
                            <textarea asp-for="Abstract" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Abstract" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TechStack" class="form-label font-weight-bold">Tech Stack</label>
                                <input asp-for="TechStack" class="form-control" />
                                <span asp-validation-for="TechStack" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ResearchArea" class="form-label font-weight-bold">Research Area</label>
                                <input asp-for="ResearchArea" class="form-control" />
                                <span asp-validation-for="ResearchArea" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />
                        
                        <div class="d-flex justify-content-between">
                            <a asp-controller="StudentDashboard" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
