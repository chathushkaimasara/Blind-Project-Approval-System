@model IEnumerable<BlindMatchPAS.Models.ProjectProposal>

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5">Student Dashboard</h1>
            <p class="text-muted">Manage your project proposals and track their status.</p>
        </div>
        <div class="col-auto">
            <a asp-controller="Proposals" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Submit New Proposal
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="card-title mb-0">My Proposals</h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-file-earmark-text display-1 text-light"></i>
                    <p class="mt-3">You haven't submitted any proposals yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Title</th>
                                <th>Research Area</th>
                                <th>Tech Stack</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><strong>@item.Title</strong></td>
                                    <td>@item.ResearchArea</td>
                                    <td>
                                        <small class="text-muted">@item.TechStack</small>
                                    </td>
                                    <td>
                                        @if (item.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else if (item.Status == "Matched")
                                        {
                                            <span class="badge bg-success">Matched</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@item.Status</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="Proposals" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (item.Status != "Matched")
                                            {
                                                <a asp-controller="Proposals" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <a asp-controller="Proposals" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
